Here's the complete content for `nanometa_live/Snakefile`:

```python
"""
Snakemake workflow for Nanometa Live.

This workflow manages the real-time metagenomic analysis pipeline, processing
sequence data from nanopore sequencers through quality control, filtering,
taxonomic classification, and validation.
"""

import os
import sys
import time
import logging
import pkg_resources
import glob
from pathlib import Path

# Configure logging
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s - %(levelname)s - %(message)s"
)

# Function to wait for directory or files to appear
def wait_for_input(condition_func, message, interval):
    """
    Wait until a condition is met, logging status at intervals.

    Args:
        condition_func: Function that returns True when condition is met
        message: Message to display while waiting
        interval: Time in seconds between checks
    """
    while not condition_func():
        logging.warning(f"{message}. Waiting for {interval} seconds...")
        time.sleep(interval)
    logging.info(f"Condition met: {message}")

# Define condition functions
is_dir_exists = lambda: os.path.isdir(config["nanopore_output_directory"])
is_files_exist = lambda: len(os.listdir(config["nanopore_output_directory"])) > 0

# Wait for input directory to exist
wait_for_input(
    is_dir_exists,
    f"Input directory {config.get('nanopore_output_directory', 'None')} not found",
    config.get("check_intervals_seconds", 15)
)

# Wait for files to appear in input directory
wait_for_input(
    is_files_exist,
    f"No files found in {config.get('nanopore_output_directory', 'None')}",
    config.get("check_intervals_seconds", 15)
)

# Process files from input directory
def glob_input_files():
    """Find all FASTQ files in the input directory."""
    pattern = os.path.join(config["nanopore_output_directory"], "*.fastq.gz")
    files = glob.glob(pattern)
    return [os.path.basename(f).replace(".fastq.gz", "") for f in files]

# Define target files for final rule
def get_target_files():
    """Define the target files for the workflow."""
    targets = [
        os.path.join(config["main_dir"], "kraken_cumul/kraken_cumul_txt.kraken2"),
        os.path.join(config["main_dir"], "kraken_cumul/kraken_cumul_report.kreport2"),
        os.path.join(config["main_dir"], "qc_data/cumul_qc.txt"),
        os.path.join(config["main_dir"], "fastp_reports/compiled_fastp.txt")
    ]

    # Add validation targets if enabled
    if config.get("blast_validation", True):
        targets.extend([
            os.path.join(config["main_dir"], "validation_fastas/force_validation.txt"),
            os.path.join(config["main_dir"], "blast_result_files/force_blast.txt")
        ])

    return targets

# Setup for blast validation if enabled
if config.get("blast_validation", True):
    def create_validation_placeholders():
        """
        Create placeholder files for species of interest.

        Returns:
            Path to placeholder directory
        """
        # Define directories
        path1 = os.path.join(config["main_dir"], "validation_fastas")
        path2 = os.path.join(config["main_dir"], "validation_fastas/placeholders")

        # Create directories
        for path in [path1, path2]:
            if not os.path.isdir(path):
                os.makedirs(path, exist_ok=True)
                logging.info(f"Created directory: {path}")

        # Create placeholder files for each species
        for species in config.get("species_of_interest", []):
            species_id = species.get("taxid")
            if species_id:
                file_path = os.path.join(path2, str(species_id))
                if not os.path.exists(file_path):
                    with open(file_path, 'w') as f:
                        f.write("placeholder file")
                    logging.info(f"Created placeholder: {file_path}")

        return path2

    # Create validation placeholders and get taxids
    valid_path = create_validation_placeholders()
    taxids = [os.path.basename(p) for p in glob.glob(os.path.join(valid_path, "*"))]
else:
    taxids = []

# Get file base names
files = glob_input_files()

# Define the rules
rule all:
    """
    Final rule that defines the target files to produce.
    """
    input:
        get_target_files()

rule extract_qc_info:
    """
    Extract quality control information from input files.
    """
    input:
        os.path.join(config["nanopore_output_directory"], "{fileName}.fastq.gz")
    output:
        os.path.join(config["main_dir"], "qc_data/{fileName}.txt")
    conda:
        pkg_resources.resource_filename('nanometa_live', 'snakemake_envs/qc_env.yaml')
    shell:
        "python {script} {{input}} {{output}}".format(
            script=pkg_resources.resource_filename('nanometa_live', 'snakemake_scripts/qc_file_creator.py')
        )

rule combine_qc:
    """
    Combine individual QC files into a cumulative file.
    """
    input:
        expand(os.path.join(config["main_dir"], "qc_data/{fileName}.txt"), fileName=files)
    output:
        os.path.join(config["main_dir"], "qc_data/cumul_qc.txt")
    shell:
        "cat {input} > {output}"

rule fastp_filtering:
    """
    Filter reads using FastP quality and length criteria.
    """
    input:
        os.path.join(config["nanopore_output_directory"], "{fileName}.fastq.gz")
    output:
        fastqs=os.path.join(config["main_dir"], "fastp_filtered/{fileName}.fastq.gz"),
        report=os.path.join(config["main_dir"], "fastp_reports/{fileName}.json")
    conda:
        pkg_resources.resource_filename('nanometa_live', 'snakemake_envs/fastp_env.yaml')
    shell:
        "fastp -i {input} -o {output.fastqs} --json {output.report} --html /dev/null"

rule extract_fastp_info:
    """
    Extract information from FastP reports.
    """
    input:
        os.path.join(config["main_dir"], "fastp_reports/{fileName}.json")
    output:
        os.path.join(config["main_dir"], "fastp_reports/{fileName}.txt")
    shell:
        "python {script} {{input}} {{output}}".format(
            script=pkg_resources.resource_filename('nanometa_live', 'snakemake_scripts/fastp_report_parser.py')
        )

rule combine_fastp:
    """
    Combine FastP reports into a cumulative file.
    """
    input:
        expand(os.path.join(config["main_dir"], "fastp_reports/{fileName}.txt"), fileName=files)
    output:
        os.path.join(config["main_dir"], "fastp_reports/compiled_fastp.txt")
    shell:
        "cat {input} > {output}"

rule run_kraken:
    """
    Run Kraken2 classification on filtered reads.
    """
    input:
        os.path.join(config["main_dir"], "fastp_filtered/{fileName}.fastq.gz")
    output:
        txt=os.path.join(config["main_dir"], "kraken_results/{fileName}.kraken2"),
        report=os.path.join(config["main_dir"], "kraken_results/{fileName}.kreport2")
    threads: config.get("kraken_cores", 1)
    conda:
        pkg_resources.resource_filename('nanometa_live', 'snakemake_envs/kraken2_env.yaml')
    shell:
        "kraken2 --db {db} {mm} --gzip-compressed --report {{output.report}} {{input}} > {{output.txt}} && rm {{input}}".format(
            db=config.get("kraken_db", ""),
            mm="--memory-mapping" if config.get("kraken_memory_mapping", True) else ""
        )

rule append_kraken_cumul:
    """
    Concatenate Kraken results into a cumulative file.
    """
    input:
        expand(os.path.join(config["main_dir"], "kraken_results/{fileName}.kraken2"), fileName=files)
    output:
        os.path.join(config["main_dir"], "kraken_cumul/kraken_cumul_txt.kraken2")
    shell:
        "cat {input} > {output}"

rule combine_kreports:
    """
    Combine Kraken reports into a cumulative report.
    """
    input:
        expand(os.path.join(config["main_dir"], "kraken_results/{fileName}.kreport2"), fileName=files)
    output:
        os.path.join(config["main_dir"], "kraken_cumul/kraken_cumul_report.kreport2")
    conda:
        pkg_resources.resource_filename('nanometa_live', 'snakemake_envs/combine_kreports_env.yaml')
    shell:
        "python {script} --no-headers --only-combined -r {{input}} -o {{output}}".format(
            script=pkg_resources.resource_filename('nanometa_live', 'snakemake_scripts/combine_kreports.py')
        )

# Validation rules only run if blast_validation is enabled
if config.get("blast_validation", True):
    rule concat_fastqs:
        """
        Combine all input FASTQ files for validation.
        """
        input:
            expand(os.path.join(config["nanopore_output_directory"], "{fileName}.fastq.gz"), fileName=files)
        output:
            os.path.join(config["main_dir"], "validation_fastas/combined_fastqs.fastq.gz")
        shell:
            "cat {input} > {output}"

    rule extract_validation_seqs:
        """
        Extract sequences for validation based on Kraken results.
        """
        input:
            kraken_txt=os.path.join(config["main_dir"], "kraken_cumul/kraken_cumul_txt.kraken2"),
            fastqs=os.path.join(config["main_dir"], "validation_fastas/combined_fastqs.fastq.gz"),
            valids=os.path.join(config["main_dir"], "validation_fastas/placeholders/{ID}")
        output:
            os.path.join(config["main_dir"], "validation_fastas/valid_seqs_{ID}.fasta")
        threads: config.get("validation_cores", 1)
        conda:
            pkg_resources.resource_filename('nanometa_live', 'snakemake_envs/extract_validation_env.yaml')
        shell:
            "python {script} -k {{input.kraken_txt}} -s {{input.fastqs}} -o {{output}} --taxid $(basename {{input.valids}})".format(
                script=pkg_resources.resource_filename('nanometa_live', 'snakemake_scripts/extract_kraken_reads.py')
            )

    rule force_validation:
        """
        Create a file to track validation completion.
        """
        input:
            id_names=expand(os.path.join(config["main_dir"], "validation_fastas/valid_seqs_{ID}.fasta"), ID=taxids),
            fastq=os.path.join(config["main_dir"], "validation_fastas/combined_fastqs.fastq.gz")
        output:
            os.path.join(config["main_dir"], "validation_fastas/force_validation.txt")
        shell:
            """
            for file in {input.id_names}; do
                echo $(basename "$file") >> {output}
            done
            rm -f {input.fastq}
            """

    rule run_blast:
        """
        Run BLAST validation on extracted sequences.
        """
        input:
            id_fasta=os.path.join(config["main_dir"], "validation_fastas/valid_seqs_{ID}.fasta"),
            database=os.path.join(config["main_dir"], "data-files/blast/{ID}.fasta.nsq")
        output:
            os.path.join(config["main_dir"], "blast_result_files/{ID}.txt")
        threads: config.get("blast_cores", 1)
        conda:
            pkg_resources.resource_filename('nanometa_live', 'snakemake_envs/blast_validation_env.yaml')
        shell:
            "blastn -db $(dirname {input.database})/$(basename {input.database} .nsq) "
            "-query {input.id_fasta} -out {output} -outfmt 6 "
            "-perc_identity {perc_id} -evalue {e_val}".format(
                perc_id=config.get("min_perc_identity", 90),
                e_val=config.get("e_val_cutoff", 0.01)
            )

    rule force_blast:
        """
        Create a file to track BLAST completion.
        """
        input:
            id_names=expand(os.path.join(config["main_dir"], "blast_result_files/{ID}.txt"), ID=taxids)
        output:
            os.path.join(config["main_dir"], "blast_result_files/force_blast.txt")
        shell:
            """
            for file in {input.id_names}; do
                echo $(basename "$file") >> {output}
            done
            """

# Cleanup rule to run at the end if enabled
onsuccess:
    if config.get("remove_temp_files", True):
        logging.info("Cleaning up temporary files...")

        # Define paths to clean
        kraken_results_dir = os.path.join(config["main_dir"], "kraken_results/")
        qc_dir = os.path.join(config["main_dir"], "qc_data/")
        qc_file_to_keep = os.path.join(config["main_dir"], "qc_data/cumul_qc.txt")
        validation_placeholders = os.path.join(config["main_dir"], "validation_fastas/placeholders")

        # Remove directories and files
        import shutil
        if os.path.exists(kraken_results_dir):
            shutil.rmtree(kraken_results_dir)
            logging.info("Removed Kraken results directory")

        # Clean QC directory but keep cumulative file
        if os.path.exists(qc_dir):
            for filename in os.listdir(qc_dir):
                file_path = os.path.join(qc_dir, filename)
                if file_path != qc_file_to_keep and os.path.isfile(file_path):
                    os.remove(file_path)
            logging.info("Cleaned QC directory, kept cumulative file")

        # Remove validation placeholders
        if os.path.exists(validation_placeholders):
            shutil.rmtree(validation_placeholders)
            logging.info("Removed validation placeholders")

        logging.info("Cleanup complete")
```